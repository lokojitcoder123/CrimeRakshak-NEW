# ── Database (shared by ingestion pipeline and Auth/RBAC API) ──
POSTGRES_URI=postgresql://user:password@localhost:5544/crimerakshak

# ── Conversational AI (LLM + DuckDB analytics) ──
# Provider: "gemini" (Google) or "openrouter".
LLM_PROVIDER=gemini
# Gemini (active provider)
GEMINI_API_KEY=REPLACE_ME
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_AGENT_MODEL=gemini-flash-lite-latest
LLM_SUMMARY_MODEL=gemini-flash-lite-latest
LLM_MAX_TOKENS=1024
# OpenRouter (alternate provider)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DATASETS_DIR=../datasets
DUCKDB_PATH=crime_stats.duckdb

# ── Neo4j (ingestion pipeline) ──
USE_NEO4J=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# ── Graph Intelligence tuning (Feature 2) ──
GRAPH_MAX_NODES=500
GRAPH_DEFAULT_LIMIT=100
GRAPH_MAX_DEPTH=5

# ── Auth / JWT ──
# Generate a strong secret: `openssl rand -hex 32`
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Security policy ──
PASSWORD_MIN_LENGTH=8
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# ── CORS (comma-separated origins) ──
BACKEND_CORS_ORIGINS=http://localhost:3000

# ── Initial superuser (used by `python -m app.seed`) ──
FIRST_SUPERUSER_USERNAME=admin
FIRST_SUPERUSER_EMAIL=admin@crimerakshak.local
FIRST_SUPERUSER_PASSWORD=ChangeMe123!
